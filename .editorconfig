root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx,json,yaml,yml,md}]
indent_size = 2

[*.{cs,csproj,props,targets}]
indent_size = 4

# C# code style
[*.cs]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# var preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Braces
csharp_prefer_braces = true:warning

# Null checks
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

# Naming conventions
dotnet_naming_rule.private_fields_should_be_camel_case.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore_prefix_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_underscore_prefix_style.required_prefix = _
dotnet_naming_style.camel_case_underscore_prefix_style.capitalization = camel_case

# ── Diagnostic severities ─────────────────────────────────────────────────────

# Unused locals / assignments
dotnet_diagnostic.IDE0059.severity = warning
# Unused parameters
dotnet_diagnostic.IDE0060.severity = warning
# Remove unnecessary using directives
dotnet_diagnostic.IDE0005.severity = warning
# Async method without await
dotnet_diagnostic.CS1998.severity = warning
# Add readonly modifier where possible
dotnet_diagnostic.IDE0044.severity = suggestion
# Use null propagation
dotnet_diagnostic.IDE0031.severity = suggestion
# Simplify string interpolation
dotnet_diagnostic.IDE0071.severity = suggestion

# CA quality rules
dotnet_diagnostic.CA1826.severity = warning
dotnet_diagnostic.CA1827.severity = warning
dotnet_diagnostic.CA1829.severity = warning
dotnet_diagnostic.CA2208.severity = warning

# ── Ignored warnings (style/low impact) ───────────────────────────────────────

# IDE0011: Add braces - purely stylistic preference
dotnet_diagnostic.IDE0011.severity = none

# CA1848: Use LoggerMessage delegates - only matters for hot paths, single calls are fine
dotnet_diagnostic.CA1848.severity = none

# CA1311/CA1304: Specify culture for string operations - false positives for LINQ-to-EF
dotnet_diagnostic.CA1311.severity = none
dotnet_diagnostic.CA1304.severity = none
