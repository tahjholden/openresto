# Root .gitignore for the repository

# Node / frontend
node_modules/
openresto-frontend/.expo/
openresto-frontend/dist/
openresto-frontend/web-build/

# .NET build outputs
**/bin/
**/obj/
*.dll
*.pdb
*.exe
*.nuget.props
*.nuget.g.targets

# VS / Rider
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.idea/

# OS files
.DS_Store
Thumbs.db

# env files
*.env

# Local secrets (never commit)
**/appsettings.Local.json

# Claude Code local settings
.claude/settings.local.json

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
**/docker-compose.override.yml

# Coverage
CoverageReport/
coverage/
**/coverage*.xml
**/TestResults/
**/coverage-report*/
.claude/settings.json
docs/superpowers/plans/2026-05-24-highlights-tags.md
# Uploaded media files
OpenRestoApi/wwwroot/media/

# VPS runtime files (live DB, SSL certs/keys, deploy scripts, logs)
data/
nginx/ssl/
auto_update.sh
update.log
# Playwright MCP plugin snapshots
.playwright-mcp/
# Session handoff notes
.remember/
docs/*
# Track user-facing docs explicitly
!docs/backup-restore.md
